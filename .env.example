# ===========================================
# Railway Deployment Environment Variables
# ===========================================

# Supabase - Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Solana RPC - Helius primary, Quicknode fallback
# Helius: https://helius.dev
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_api_key
NEXT_PUBLIC_HELIUS_RPC_URL_DEVNET=https://devnet.helius-rpc.com/?api-key=your_api_key

# Quicknode fallback: https://quicknode.com
NEXT_PUBLIC_QUICKNODE_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/your-key/

# Jupiter API Key - Get from https://station.jup.ag/docs/apis/swap-api
JUPITER_API_KEY=your_jupiter_api_key_here

# App URL - Set this to your Railway domain
NEXT_PUBLIC_APP_URL=https://your-app.railway.app

# Keeper Authentication - Generate a random string for cron job auth
# Example: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# Optional: Customize keeper schedule (default: every 15 minutes)
# Uses standard cron syntax
# KEEPER_CRON_SCHEDULE=*/15 * * * *

# GRAIL Gold Integration (Devnet POC)
GRAIL_PARTNER_ID=your_partner_id
GRAIL_CENTRAL_VAULT_WALLET=your_central_vault_address
GRAIL_EXECUTIVE_AUTHORITY_API_KEY=your_api_key
GRAIL_PRIVATE_KEY=your_private_key_base58
# Solana Blinks / Actions - Escrow wallet for receiving Blink DCA deposits
# Generate keypair: solana-keygen new --no-bip39-passphrase -o escrow.json
# Then base64 encode: cat escrow.json | python3 -c "import sys,json,base64; print(base64.b64encode(bytes(json.load(sys.stdin))).decode())"
BLINK_ESCROW_KEYPAIR_BASE64=your_base64_encoded_keypair_here

# Encryption key for Blink session keypairs (AES-256-GCM)
# Generate: openssl rand -hex 32
BLINK_ENCRYPTION_KEY=your_64_char_hex_string_here

# Analytics - Umami (privacy-friendly)
# Get your website ID from https://cloud.umami.is
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_website_id_here
